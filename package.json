{
  "name": "queuekeeper",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @queuekeeper/web dev",
    "dev:agent": "pnpm --filter @queuekeeper/agent dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @queuekeeper/core test && cd contracts && forge test -vv",
    "test:smoke": "playwright test -c playwright.config.ts",
    "test:smoke:headed": "playwright test -c playwright.config.ts --headed",
    "playwright:install": "playwright install chromium"
  },
  "pnpm": {
    "overrides": {
      "@metamask/sdk": "0.33.1",
      "@metamask/sdk-communication-layer": "0.33.1",
      "underscore": "1.13.8"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "1.55.0"
  }
}
