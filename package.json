{
  "name": "queuekeeper",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @queuekeeper/web dev",
    "dev:agent": "pnpm --filter @queuekeeper/agent dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
